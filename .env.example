# Meta Marketing API
META_APP_ID=your_app_id
META_APP_SECRET=your_app_secret
META_ACCESS_TOKEN=your_long_lived_token
META_AD_ACCOUNT_ID=act_XXXXXXXXXX
META_API_VERSION=v21.0
META_PAGE_ID=your_facebook_page_id
META_PIXEL_ID=your_meta_pixel_id
META_DEFAULT_LINK_URL=https://your-store-url.com

# Anthropic Claude API
ANTHROPIC_API_KEY=your_claude_api_key
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# MongoDB
MONGODB_URI=mongodb://localhost:27017/ai-meta-ads

# Dashboard
DASHBOARD_PORT=3500
DASHBOARD_SECRET=your_jwt_secret
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=your_secure_password

# OpenAI (gpt-image-1.5)
OPENAI_API_KEY=your_openai_api_key

# Black Forest Labs FLUX 2 Pro (image editing)
BFL_API_KEY=your_bfl_api_key

# Freepik Seedream 4.5 Edit (image editing)
FREEPIK_API_KEY=your_freepik_api_key

# Web Search (para Strategic Agent — al menos uno requerido para research)
BRAVE_SEARCH_API_KEY=your_brave_search_api_key
SERP_API_KEY=your_serp_api_key

# Sistema
NODE_ENV=development
LOG_LEVEL=info
TIMEZONE=America/New_York
DECISION_ENGINE_MODE=unified_shadow
UNIFIED_POLICY_MODE=shadow

# Uploads (en Render usar /tmp/uploads)
UPLOADS_DIR=/tmp/uploads
